{
  "name": "marplux",
  "version": "0.0.0",
  "description": "A tiny, zero-dependency CLI that augments Marp decks — starting with auto-inserted agenda recap slides before each heading.",
  "keywords": [
    "marp",
    "markdown",
    "slides",
    "agenda",
    "presentation",
    "cli"
  ],
  "license": "MIT",
  "author": "tomoya",
  "type": "module",
  "bin": {
    "marplux": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "volta": {
    "node": "24.14.0",
    "pnpm": "10.27.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/node": "^20.17.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}